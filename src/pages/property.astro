---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { property } from '../data/property.js';
---
<BaseLayout title="Property Overview" description="Property overview for 1 Woodland Drive in Augusta, Kansas.">
  <section class="hero compact" style={`--hero-image: url('/assets/images/exterior/front-yard-wide.jpeg')`}><div class="hero-overlay"></div><div class="hero-content section-wrap"><p class="eyebrow">Property overview</p><h1>Classic ranch comfort with modern updates.</h1></div></section>
  <section class="section-wrap">
    <div class="split">
      <div>
        <SectionHeader eyebrow="The residence" title="Built to last. Updated to enjoy." text="This traditional ranch has stood the test of time and has now been refreshed for the next chapter." />
        <p>The home includes approximately 2,700 square feet plus bonus finished lower-level space. The main level features a fully remodeled kitchen, new appliances, main-floor laundry, fresh finishes, and an easy everyday layout.</p>
        <p>The finished lower level adds bonus living space, including an office with an adjoining private bath — ideal for working from home or hosting guests.</p>
      </div>
      <div class="card">
        <ul class="check-list">
          <li>{property.bedrooms} bedrooms</li>
          <li>{property.bathrooms} bathrooms</li>
          <li>{property.yearBuilt} construction</li>
          <li>{property.squareFeet}</li>
          <li>{property.acreage}</li>
          <li>Finished lower level</li>
          <li>Main-floor laundry</li>
          <li>New well-fed sprinkler system (2025)</li>
          <li>New HVAC system</li>
          <li>Home warranty included</li>
          <li>Termite warranty included</li>
          <li>One year of lawn treatments</li>
        </ul>
      </div>
    </div>
  </section>
  <section class="section-wrap flush-top">
    <div class="grid two">
      <div class="image-card"><img src="/assets/images/bedrooms/primary-suite.jpeg" alt="Primary suite at 1 Woodland Drive" loading="lazy" /></div>
      <div class="image-card"><img src="/assets/images/bathrooms/hall-bathroom.jpeg" alt="Updated hall bathroom at 1 Woodland Drive" loading="lazy" /></div>
    </div>
  </section>
</BaseLayout>
