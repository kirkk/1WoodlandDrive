---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import { property } from '../data/property.js';
---
<BaseLayout title="Gallery" description="Photo gallery for 1 Woodland Drive in Augusta, Kansas, including exterior, living areas, bedrooms, bathrooms, and shop views.">
  <section class="hero compact" style={`--hero-image: url('/assets/images/exterior/front-drive-day.jpeg')`}><div class="hero-overlay"></div><div class="hero-content section-wrap"><p class="eyebrow">Gallery</p><h1>A look inside and out.</h1></div></section>
  <section class="section-wrap">
    <SectionHeader title="Every space, staged and ready." text="Browse the living areas, primary suite, updated bathrooms, exterior grounds, and the detached garage/shop. Click any photo to view it larger." />
    <div class="gallery-grid gallery-grid-large" data-gallery>
      {property.gallery.map((image, index) => (
        <a class="gallery-item" href={image.src} data-index={index} aria-label={`View larger image: ${image.title}`}>
          <img src={image.src} alt={image.alt || image.title} loading="lazy" />
          <div><span>{image.category}</span><strong>{image.title}</strong></div>
        </a>
      ))}
    </div>
  </section>
  <div class="lightbox" data-lightbox hidden>
    <button class="lightbox-close" data-lb-close aria-label="Close">&times;</button>
    <button class="lightbox-nav lightbox-prev" data-lb-prev aria-label="Previous photo">&#8249;</button>
    <figure>
      <img data-lb-img src="" alt="" />
      <figcaption><span data-lb-category></span><strong data-lb-title></strong></figcaption>
    </figure>
    <button class="lightbox-nav lightbox-next" data-lb-next aria-label="Next photo">&#8250;</button>
  </div>
  <script is:inline>
    (() => {
      const items = [...document.querySelectorAll('[data-gallery] .gallery-item')];
      const box = document.querySelector('[data-lightbox]');
      const img = box.querySelector('[data-lb-img]');
      const cat = box.querySelector('[data-lb-category]');
      const ttl = box.querySelector('[data-lb-title]');
      let current = 0;
      const show = (i) => {
        current = (i + items.length) % items.length;
        const item = items[current];
        img.src = item.href;
        img.alt = item.querySelector('img')?.alt || '';
        cat.textContent = item.querySelector('span')?.textContent || '';
        ttl.textContent = item.querySelector('strong')?.textContent || '';
      };
      const open = (i) => { show(i); box.hidden = false; document.body.style.overflow = 'hidden'; };
      const close = () => { box.hidden = true; img.src = ''; document.body.style.overflow = ''; };
      items.forEach((item, i) => item.addEventListener('click', (e) => { e.preventDefault(); open(i); }));
      box.querySelector('[data-lb-close]').addEventListener('click', close);
      box.querySelector('[data-lb-prev]').addEventListener('click', () => show(current - 1));
      box.querySelector('[data-lb-next]').addEventListener('click', () => show(current + 1));
      box.addEventListener('click', (e) => { if (e.target === box) close(); });
      document.addEventListener('keydown', (e) => {
        if (box.hidden) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') show(current - 1);
        if (e.key === 'ArrowRight') show(current + 1);
      });
    })();
  </script>
</BaseLayout>
